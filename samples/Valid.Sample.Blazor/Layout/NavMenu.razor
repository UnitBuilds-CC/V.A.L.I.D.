<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">VALID 3.0.0 HUD</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-cpu-fill" aria-hidden="true"></span> SpaceShuttle HUD
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="grid">
                <span class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></span> Vectorized Grid (100k)
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pro-grid">
                <span class="bi bi-layout-three-columns" aria-hidden="true"></span> Axiom Pro Grid (1M)
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="comparison">
                <span class="bi bi-shield-shaded" aria-hidden="true"></span> Vavid vs Blazor
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
