@page "/benchmark-industrial"
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@using Valid
@using Valid.Sample.Blazor.Components
@using System.Diagnostics
@using System.Timers
@namespace Valid.Sample.Blazor.Pages

<style>
    .performance-dashboard {
        background: #1a1a1a;
        color: #00ff00;
        padding: 1.5rem;
        border-radius: 12px;
        font-family: 'Consolas', monospace;
        margin-bottom: 2rem;
        border: 1px solid #333;
        display: flex;
        gap: 2rem;
        align-items: center;
    }
    .engine-tag {
        padding: 0.4rem 1rem;
        border-radius: 6px;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.8rem;
    }
    .tag-vavid { background: #004d00; border: 1px solid #00ff00; color: #00ff00; }
    .tag-blazor { background: #4d0000; border: 1px solid #ff4d4d; color: #ff4d4d; }
    
    .fps-meter {
        font-size: 2rem;
        font-weight: bold;
    }
    .stat-label { color: #888; font-size: 0.75rem; display: block; }
</style>

<div class="benchmark-industrial" style="padding: 2rem; max-width: 1400px; margin: 0 auto;">
    
    <div class="performance-dashboard">
        <div style="flex: 1;">
            <span class="stat-label">Active Rendering Engine</span>
            <div style="display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem;">
                <div class="engine-tag @(UseVavidBypass ? "tag-vavid" : "tag-blazor")">
                    @(UseVavidBypass ? "V.A.L.I.D. Bypass (Industrial)" : "Standard Blazor VDOM")
                </div>
                <button @onclick="ToggleRenderingMode" class="btn btn-outline-light btn-sm">SWITCH ENGINE</button>
            </div>
        </div>

        <div style="text-align: center; min-width: 100px;">
            <span class="stat-label">Frame Rate</span>
            <div class="fps-meter">@Telemetry.FPS <span style="font-size: 1rem;">FPS</span></div>
        </div>

        <div style="text-align: center; min-width: 120px;">
            <span class="stat-label">C# Pulse Latency</span>
            <div style="font-size: 1.5rem; font-weight: bold;">@LastRenderTimeMs <span style="font-size: 0.8rem;">ms</span></div>
        </div>

        <div style="flex: 1; text-align: right;">
            <h1 style="margin: 0; font-size: 1.5rem; color: #fff;">Industrial Performance Lab</h1>
            <p style="color: #888; margin: 0;">2,000 Rows | 10,000 Linked Fields</p>
        </div>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h2 style="margin: 0;">Real-Time Data Matrix</h2>
        </div>
        <div style="display: flex; gap: 1rem;">
             <button @onclick="TriggerChaosBurst" class="btn btn-danger" style="padding: 0.8rem 2rem; font-weight: bold; border-radius: 8px; box-shadow: 0 4px 15px rgba(255,0,0,0.3);">
                🔥 TRIGGER 10,000 FIELD BURST
            </button>
        </div>
    </div>

    @if (Model != null)
    {
        <BenchmarkGrid Items="Model.Items" />
    }
</div>

@code {
    private BenchmarkModel? Model;
    private bool UseVavidBypass = true;
    private TelemetryData Telemetry = new();
    private long LastRenderTimeMs = 0;
    private Timer? _telemetryTimer;

    protected override void OnInitialized()
    {
        // 2,000 rows * 5 fields = 10,000 fields
        Model = new BenchmarkModel(2000);
        
        for (int i = 0; i < Model.Items.Count; i++)
        {
            Model.Items[i].SlabIndex = i + 1;
        }

        _telemetryTimer = new Timer(500);
        _telemetryTimer.Elapsed += async (s, e) => await UpdateTelemetry();
        _telemetryTimer.AutoReset = true;
        _telemetryTimer.Enabled = true;

        VavidSurgicalComponentBase.ForceStandardRendering = false;
    }

    private async Task UpdateTelemetry()
    {
        try 
        {
            var data = await JSRuntime.InvokeAsync<TelemetryData>("__VAVID_GET_TELEMETRY__");
            if (data != null)
            {
                Telemetry = data;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            WebWorkerBridge.Initialize(1000000); 
            WebWorkerBridge.SetMagicPulse();

            var ptr = WebWorkerBridge.GetStatePointer();
            var len = WebWorkerBridge.GetSlabLength();
            await JSRuntime.InvokeVoidAsync("__VAVID_INITIALIZE_INDUSTRIAL_BYPASS__", (long)ptr, len);
        }
    }

    private async Task ToggleRenderingMode()
    {
        UseVavidBypass = !UseVavidBypass;
        VavidSurgicalComponentBase.ForceStandardRendering = !UseVavidBypass;
        await JSRuntime.InvokeVoidAsync("__VAVID_SET_BYPASS_ENABLED__", UseVavidBypass);
        StateHasChanged();
    }

    private void TriggerChaosBurst()
    {
        if (Model == null) return;
        
        var sw = Stopwatch.StartNew();
        var rnd = new Random();
        
        // Mutate EVERY visible row (Industrial Stress)
        for (int i = 0; i < Model.Items.Count; i++)
        {
            var item = Model.Items[i];
            item.Quantity = rnd.Next(1, 100);
            item.UnitPrice = rnd.Next(10, 500);
            item.Value1 = "V.A.L.I.D. PUSH " + rnd.Next(100);
        }

        if (!UseVavidBypass)
        {
            // Standard Blazor must re-render the whole matrix
            StateHasChanged();
        }

        sw.Stop();
        LastRenderTimeMs = sw.ElapsedMilliseconds;
    }

    public class TelemetryData 
    {
        public int FPS { get; set; }
        public int ActiveRows { get; set; }
        public bool Enabled { get; set; }
    }

    public void Dispose()
    {
        _telemetryTimer?.Dispose();
    }
}
