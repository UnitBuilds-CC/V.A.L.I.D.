@using Valid
@using Microsoft.JSInterop
@inject IJSRuntime JsRuntime

@{
    var vo = Model ?? CascadedModel;
}

@if (vo != null && vo.ErrorFlags != System.UInt128.Zero)
{
    var diagnostics = vo.GetDiagnostics().ToList();
    if (diagnostics.Count > 0)
    {
        <div class="vavid-error-strip vavid-glass flex gap-2 p-2 rounded shadow-lg overflow-x-auto" vavid-obj="@vo.GetHashCode()">
            <span class="text-[10px] text-red-500 font-bold uppercase tracking-widest flex items-center pr-2 border-r border-red-500/30">
                Validation Errors
            </span>
            <div class="flex gap-2">
                @foreach (var diag in diagnostics)
                {
                    <span class="vavid-error-chip text-[11px] px-2 py-1 rounded bg-red-900/30 border border-red-500/50 text-red-100 whitespace-nowrap" vavid-bit="@vo.GetBitIndex(diag.Property)">
                        @diag.Message
                    </span>
                }
            </div>
        </div>
    }
}

<style>
    .vavid-error-strip {
        border: 1px solid rgba(255, 0, 0, 0.2);
        animation: vavid-error-glow 2s infinite;
    }
    
    @@keyframes vavid-error-glow {
        0% { box-shadow: 0 0 5px rgba(255, 0, 0, 0.1); }
        50% { box-shadow: 0 0 15px rgba(255, 0, 0, 0.3); }
        100% { box-shadow: 0 0 5px rgba(255, 0, 0, 0.1); }
    }

    .vavid-error-chip {
        cursor: pointer;
        transition: all 0.2s;
    }
    .vavid-error-chip:hover {
        background: rgba(255, 0, 0, 0.4);
        transform: translateY(-1px);
    }
</style>

@code {
    [CascadingParameter] public IValidObject? CascadedModel { get; set; }
    [Parameter] public IValidObject? Model { get; set; }
}
