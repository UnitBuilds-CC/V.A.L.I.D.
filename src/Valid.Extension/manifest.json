{
  "manifest_version": 3,
  "name": "V.A.V.I.D. HUD",
  "version": "3.0.7",
  "description": "Industrial HUD for the V.A.L.I.D. framework. Provides real-time bitmask inspection, security auditing, delta streams, and performance profiling.",
  "permissions": ["activeTab", "scripting", "storage"],
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["hud.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
